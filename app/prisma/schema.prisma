// Lisa CRM — Datenmodell MVP
// Provider auf "postgresql" umgestellt für Vercel/Supabase-Deploy.
// Lokal weiter SQLite testen: temporär `provider = "sqlite"` + `DATABASE_URL="file:./dev.db"`.
// Mittelfristig sollte die lokale Dev-DB ebenfalls Postgres sein (Docker / Supabase local).

generator client {
  provider      = "prisma-client-js"
  // rhel-openssl-3.0.x: Vercel-Serverless Linux Runtime.
  // Ohne dies muss Prisma im Cold-Start den Binary erst herunterladen → spart 2–3s.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -------------------- AUTH --------------------

model User {
  id                     String                  @id @default(cuid())
  email                  String                  @unique
  passwordHash           String
  name                   String
  // Studio-Profil (für öffentliche Kundenansicht)
  studioName             String?
  studioPhone            String?
  studioEmail            String?
  studioWebsite          String?
  studioAddress          String? // mehrzeilig
  studioInstagram        String?
  // Schnellkontakt-Kanäle (Kundenseite). Beide optional + visibility-toggles.
  studioWhatsapp         String?  // Nummer in beliebigem Format, wird beim Rendern sanitized.
  studioTelegram         String?  // @username oder t.me-URL, wird normalisiert.
  // Visibility-Toggles für die Kundenansicht. Default: alle sichtbar (rückwärts-kompatibel).
  // Lisa kann pro Feld entscheiden, ob es im Public-Footer erscheinen soll.
  showStudioPhone        Boolean                 @default(true)
  showStudioEmail        Boolean                 @default(true)
  showStudioWebsite      Boolean                 @default(true)
  showStudioAddress      Boolean                 @default(true)
  showStudioInstagram    Boolean                 @default(true)
  showStudioWhatsapp     Boolean                 @default(true)
  showStudioTelegram     Boolean                 @default(true)
  // Public-Lead-Form-Slug. Wenn null → Feature für diesen User aus.
  // Format: kurzer URL-safe Slug, z.B. „lisa-boudoir".
  leadSlug               String?                 @unique
  leads                  Lead[]
  // SMTP-Konfiguration für Email-Notifications an Kundinnen.
  // EU-Stack: Lisa pflegt ihre eigenen SMTP-Zugangsdaten (z.B. Mailbox.org, IONOS) —
  // damit bleibt die App provider-agnostisch und CLOUD-Act-frei.
  smtpHost               String?
  smtpPort               Int?
  smtpSecure             Boolean                 @default(true)
  smtpUser               String?
  smtpPasswordEnc        String? // AES-256-GCM (lib/crypto.ts) — gleiches Verfahren wie Stripe-Keys
  smtpFromEmail          String?
  smtpFromName           String?
  // Default-Vorbelegung der „Kundin benachrichtigen?"-Checkbox bei Action-Forms.
  // Lisa kann pro Action immer noch manuell entscheiden.
  emailNotifyDefault     Boolean                 @default(false)
  // Automatische Zahlungsbestätigung: bei „Rechnung als bezahlt markiert"
  // (manuell oder via Stripe-Webhook) werden Bestätigungs-Mails versendet.
  payConfirmCustomer     Boolean                 @default(true)  // an die Kundin
  payConfirmOwner        Boolean                 @default(true)  // an Lisa selbst
  studioTagline          String? // kleiner Satz unter dem Namen
  // Studio-Logo (für Customer-Portal + Rechnungs-PDF)
  // logoUrl: das verwendete Logo (gecropped bei Raster, original bei SVG)
  // logoOriginalUrl: das Ausgangsbild — erlaubt Re-Cropping ohne neuen Upload
  logoUrl                String?
  logoOriginalUrl        String?
  logoMimeType           String? // image/svg+xml | image/png | image/jpeg
  // Rechnungs-Profil (Pflichtangaben §14 UStG)
  invoiceCompanyName     String? // Firmenname / "Lisa Steiner Photography"
  invoiceCompanyOwner    String? // Inhaberin/Inhaber (bei Einzelunternehmen)
  invoiceStreet          String?
  invoiceZip             String?
  invoiceCity            String?
  invoiceCountry         String?                 @default("Deutschland")
  invoiceEmail           String? // separate Rechnungs-Mail (Footer/Versand)
  invoiceTaxId           String? // Steuernummer (z.B. 207/123/45678)
  invoiceVatId           String? // USt-IdNr (DE123456789)
  isSmallBusiness        Boolean                 @default(true) // §19 UStG Kleinunternehmer
  defaultVatRate         Float                   @default(19) // 19, 7, 0
  invoiceBankName        String?
  invoiceBankAccountName String?  // Kontoinhaber:in (z.B. bei abweichendem Namen)
  invoiceIban            String?
  invoiceBic             String?
  invoiceFooterNote      String?
  invoiceNumberFormat    String                  @default("{YYYY}-{####}") // Tokens YYYY, YY, MM, ####, ###
  invoiceCounterYear     Int                     @default(0) // letzter zurückgesetzter Jahres-Counter
  invoiceCounter         Int                     @default(0) // laufender Zähler (innerhalb des Jahres)
  // Angebots-Nummerierung (analog Rechnungen, eigener Counter)
  offerNumberFormat      String                  @default("A-{YYYY}-{####}")
  offerCounterYear       Int                     @default(0)
  offerCounter           Int                     @default(0)
  invoicePaymentDueDays  Int                     @default(14)
  // Design-Variante für die Rechnungs-PDF. "classic" (DIN 5008 plain), "elegant"
  // (Serif-Headings, warmer Akzent), "modern" (Akzentleiste oben, kräftiger).
  invoiceDesign          String                  @default("classic")
  // Mahnwesen-Defaults
  reminderDays1          Int                     @default(7) // Zahlungserinnerung: X Tage nach Fälligkeit
  reminderDays2          Int                     @default(7) // 1. Mahnung: X Tage nach Erinnerung
  reminderDays3          Int                     @default(14) // 2. Mahnung: X Tage nach 1. Mahnung
  reminderFee1Cents      Int                     @default(0) // Zahlungserinnerung: keine Gebühr
  reminderFee2Cents      Int                     @default(500) // 1. Mahnung: 5,00 €
  reminderFee3Cents      Int                     @default(1000) // 2. Mahnung: 10,00 €
  // Stripe-Konfiguration (per User → eigenes Stripe-Konto)
  stripePublishableKey   String? // pk_live_… oder pk_test_… (öffentlich, unverschlüsselt)
  stripeSecretKeyEnc     String? // sk_… AES-256-GCM verschlüsselt (siehe lib/crypto.ts)
  stripeWebhookSecretEnc String? // whsec_… AES-256-GCM verschlüsselt
  stripeAccountId        String? // gecacht aus accounts.retrieve() für Anzeige
  stripeAccountName      String?
  stripeAccountCountry   String?
  stripeChargesEnabled   Boolean                 @default(false) // gecacht: live/test ready?
  stripeLivemode         Boolean                 @default(false)
  stripeKeysUpdatedAt    DateTime?
  // Team
  teamMember             TeamMember?             @relation("UserSelfLink")
  // Externe Kalender-Verbindungen (Google, Microsoft, Apple, CalDAV)
  calendarConnections    CalendarConnection[]
  // --- Multi-Tenancy: alle owned-Entities die diesem User gehören ---
  customers              Customer[]
  customerStatuses       CustomerStatus[]
  tags                   Tag[]
  teamMembers            TeamMember[]            @relation("UserOwnsTeam")
  teamExpertises         TeamExpertise[]
  shootings              Shooting[]
  shootingStatuses       ShootingStatus[]
  packages               Package[]
  addons                 Addon[]
  bookingTypes           BookingType[]
  bookings               Booking[]
  invoices               Invoice[]
  offers                 Offer[]
  workflows              Workflow[]
  workflowRuns           WorkflowRun[]
  tasks                  Task[]
  activities             Activity[]
  paymentSchedules       PaymentSchedule[]
  questionnaireTemplates QuestionnaireTemplate[]
  availabilityWeekly     AvailabilityWeekly[]
  availabilityOverrides  AvailabilityOverride[]
  // Onboarding: nach erstem Login Setup-Wizard zeigen, bis User ihn schließt.
  onboardingDismissed    Boolean                 @default(false)
  // UI-Theme. Werte: "lisa" | "studio" | "midnight". Mapped auf data-theme="…" am <html>.
  theme                  String                  @default("lisa")
  // Dashboard-Widget-Auswahl als JSON-Array (z.B. ["revenue_month","shootings_month",...]).
  // null = Default-Set. Whitelist + Cap im Server-Action; Safe-Parse im Server-Component.
  dashboardWidgets       String?
  // Paket-Struktur: "all_in_one" = klassisches Komplettpaket pro Shooting,
  // "modular" = Anzahlungs-Paket (Solo/Couple/Reise) + separates Bildpaket.
  packageMode            String                  @default("all_in_one")
  // "Ganzer Tag" — Standardfenster, das bei AvailabilityWeekly/Override ohne slotsJson greift.
  // Auch der "Ganzer Tag"-Quick-Button im Kalender füllt diese Range ein.
  defaultDayStartMinutes Int                     @default(540) // 09:00
  defaultDayEndMinutes   Int                     @default(1080) // 18:00
  // User-konfigurierbare Quick-Preset-Zeiten (für „Vormittag/Nachmittag/Abend"-Buttons im AvailabilityManager).
  defaultMorningStart    Int                     @default(540)  // 09:00
  defaultMorningEnd      Int                     @default(780)  // 13:00
  defaultAfternoonStart  Int                     @default(840)  // 14:00
  defaultAfternoonEnd    Int                     @default(1080) // 18:00
  defaultEveningStart    Int                     @default(1080) // 18:00
  defaultEveningEnd      Int                     @default(1320) // 22:00
  // Shooting-Slot-Planungstage: Lisa markiert Tage vorab, an denen sie Shootings anbieten will.
  shootingPlanDays       ShootingPlanDay[]
  noteTemplates          NoteTemplate[]
  articleCatalog         ArticleCatalog[]
  // Persönliche Meeting-Räume pro Provider (Tier-1-Fallback). Wenn OAuth-Verbindung
  // existiert, wird stattdessen pro Buchung ein eigenes Meeting erstellt.
  zoomPersonalLink       String?
  googleMeetPersonalLink String?
  teamsPersonalLink      String?
  wherebyPersonalLink    String?
  // OAuth-Tokens (Tier 2): AES-256-GCM verschlüsselt via lib/crypto.ts.
  // Bei vorhandenem Token wird pro Buchung ein unique Meeting via Provider-API erstellt.
  zoomAccessTokenEnc     String?
  zoomRefreshTokenEnc    String?
  zoomTokenExpiresAt     DateTime?
  zoomAccountEmail       String?
  zoomUserId             String?
  googleAccessTokenEnc   String?
  googleRefreshTokenEnc  String?
  googleTokenExpiresAt   DateTime?
  googleAccountEmail     String?
  createdAt              DateTime                @default(now())
}

// -------------------- TEAM --------------------

model TeamExpertise {
  id      String       @id @default(cuid())
  label   String
  color   String       @default("#9F877F")
  members TeamMember[]
  owner   User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId String      

  @@unique([ownerId, label])
  @@index([ownerId])
}

model TeamMember {
  id               String          @id @default(cuid())
  firstName        String
  lastName         String
  role             String? // "Inhaberin", "Assistenz Make-up", "Second Shooter" …
  email            String?
  phone            String?
  avatarUrl        String?
  bio              String? // mehrzeilig
  instagram        String?
  facebook         String?
  tiktok           String?
  website          String?
  expertise        TeamExpertise[]
  isOwner          Boolean         @default(false)
  // Self-Link: wenn TeamMember = Owner (Lisa selbst), verknüpft mit Auth-User.
  user             User?           @relation("UserSelfLink", fields: [linkedUserId], references: [id])
  linkedUserId     String?         @unique
  // Tenant-Owner: zu welchem Account/User gehört dieser TeamMember
  owner            User            @relation("UserOwnsTeam", fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId          String         
  position         Int             @default(0)
  // Beziehungen
  packagesPrimary  Package[]       @relation("PackageDefaultContact")
  packagesMembers  Package[]       @relation("PackageDefaultTeam")
  shootingsPrimary Shooting[]      @relation("ShootingPrimaryContact")
  shootingsMembers Shooting[]      @relation("ShootingTeam")
  createdAt        DateTime        @default(now())

  @@index([ownerId])
}

// -------------------- KUNDEN --------------------

model CustomerStatus {
  id        String     @id @default(cuid())
  label     String
  color     String // Hex, z.B. "#C8102E"
  position  Int        @default(0)
  isDefault Boolean    @default(false)
  customers Customer[]
  owner     User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId   String    

  @@unique([ownerId, label])
  @@index([ownerId])
}

model Tag {
  id        String     @id @default(cuid())
  label     String
  color     String     @default("#9F877F")
  customers Customer[] @relation("CustomerTags")
  owner     User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId   String    

  @@unique([ownerId, label])
  @@index([ownerId])
}

// -------------------- RECHNUNGEN --------------------
// Hinweis: alle Beträge in CENT (Integer) gespeichert, um Rundungsfehler zu vermeiden.
// Sobald eine Rechnung ISSUED ist, sind issuerSnapshot, recipient*, items, Beträge
// und Nummer IMMUTABLE — Korrekturen nur via Stornorechnung (kind=CANCEL).

model Invoice {
  id                     String              @id @default(cuid())
  // Rechnungs-Lifecycle
  number                 String?             @unique // wird erst bei ISSUED vergeben (lückenlos)
  kind                   String              @default("FINAL") // DEPOSIT | INTERIM | FINAL | CANCEL
  status                 String              @default("DRAFT") // DRAFT | ISSUED | PAID | OVERDUE | CANCELLED
  // Verknüpfung
  customer               Customer            @relation(fields: [customerId], references: [id])
  customerId             String
  shooting               Shooting?           @relation(fields: [shootingId], references: [id])
  shootingId             String?
  installment            PaymentInstallment? @relation("InstallmentInvoice")
  // Bezug auf Anzahlungen (Schlussrechnung referenziert ihre Anzahlungen)
  parentInvoice          Invoice?            @relation("InvoiceChain", fields: [parentInvoiceId], references: [id])
  parentInvoiceId        String?
  childInvoices          Invoice[]           @relation("InvoiceChain")
  // Storno-Verkettung
  cancelsInvoiceId       String?             @unique
  cancelsInvoice         Invoice?            @relation("InvoiceCancel", fields: [cancelsInvoiceId], references: [id])
  cancelledByInvoice     Invoice?            @relation("InvoiceCancel")
  // Schnappschuss Empfänger (immutable bei ISSUED)
  recipientName          String
  recipientAddress       String // mehrzeilig
  // Schnappschuss Aussteller (JSON, immutable)
  issuerSnapshot         String // JSON: { companyName, owner, street, zip, city, country, taxId, vatId, isSmallBusiness, bankName, iban, bic, email, phone, footerNote }
  // Pflichtdaten
  issueDate              DateTime
  serviceDate            DateTime?
  serviceDateEnd         DateTime?
  dueDate                DateTime
  // Beträge in Cent
  subtotalCents          Int // Summe Netto
  vatRate                Float // 0 (KU), 7, 19
  vatAmountCents         Int // berechnet
  totalCents             Int // Brutto
  // bereits bezahlt aus Anzahlungen (für Schlussrechnung)
  prepaidCents           Int                 @default(0)
  amountDueCents         Int // total - prepaid
  // KU-Flag im Snapshot
  isSmallBusiness        Boolean
  // Items
  items                  InvoiceItem[]
  // Tracking
  sentAt                 DateTime?
  paidAt                 DateTime?
  internalNote           String?
  // Mahnwesen
  reminderLevel          Int                 @default(0) // 0=keine, 1=Erinnerung, 2=1.Mahnung, 3=2.Mahnung
  reminders              InvoiceReminder[]
  // PDF
  pdfUrl                 String?
  // Online-Zahlung (Stripe)
  paymentLinkEnabled     Boolean             @default(true) // Bezahllink generieren/anzeigen? Pro Rechnung wählbar.
  paymentToken           String?             @unique // unguessable Token für Public-URL /k/r/[token]
  stripeSessionId        String?             @unique // cs_… (Checkout Session)
  stripeSessionUrl       String? // session.url (gleichbleibend bis Expiry)
  stripeSessionExpiresAt DateTime?
  stripePaymentIntentId  String?
  stripePaymentStatus    String? // "open" | "processing" | "paid" | "failed" | "expired"
  stripePaymentMethod    String? // "card" | "sepa_debit" | "paypal" | "klarna" | "link" | …
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  // Back-Ref: ein Angebot, das in diese Rechnung konvertiert wurde
  fromOffer              Offer?              @relation("OfferConvertedInvoice")
  // Tenant
  owner                  User                @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId                String

  @@index([customerId])
  @@index([shootingId])
  @@index([status, dueDate])
  @@index([issueDate])
  @@index([ownerId])
}

// Externer Kalender-Account (Google, Microsoft, Apple, Nextcloud, …) pro User.
// Tokens und Passwörter NUR verschlüsselt (AES-256-GCM, AAD = userId) — siehe lib/crypto.ts.
// Pro User max ein Account pro Provider (uniqueness).
model CalendarConnection {
  id                   String                  @id @default(cuid())
  user                 User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId               String
  provider             String // "google" | "microsoft" | "apple" | "nextcloud" | "mailbox" | "posteo" | "caldav_custom"
  status               String                  @default("active") // active | error | revoked
  accountEmail         String? // für Anzeige in UI
  accountLabel         String? // optional vom User vergeben
  // OAuth (Google, Microsoft)
  accessTokenEnc       String?
  refreshTokenEnc      String?
  tokenExpiresAt       DateTime?
  oauthScope           String?
  // CalDAV (Apple, Nextcloud, Mailbox.org, Posteo, generic)
  serverUrl            String?
  username             String?
  passwordEnc          String? // verschlüsseltes App-Passwort
  // Welcher Kalender innerhalb des Accounts wird synchronisiert
  externalCalendarId   String? // Google calendar ID oder CalDAV URL
  externalCalendarName String?
  externalCalendarTz   String? // IANA, z.B. "Europe/Berlin"
  // Sync-State
  syncToken            String? // Google nextSyncToken / CalDAV sync-token
  ctag                 String? // CalDAV CTag (für Pre-Check vor sync-collection)
  channelId            String? // Google Push-Channel ID
  channelSecretEnc     String? // Google Push-Channel-Token (verschlüsselt)
  channelExpiresAt     DateTime?
  lastSyncedAt         DateTime?
  lastSyncError        String?
  // Sync-Einstellungen
  pseudonymize         Boolean                 @default(false) // exportierte Events tragen Pseudonym statt Klarnamen
  syncEnabled          Boolean                 @default(true)
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  externalEvents       ExternalCalendarEvent[]
  selectedCalendars    SelectedCalendar[]

  @@unique([userId, provider])
  @@index([userId])
}

// Mehrere Kalender pro Connection auswählbar (z.B. Privat + Business).
// Genau einer davon ist `isPushTarget = true` — dort werden eigene Shootings angelegt.
// Alle ausgewählten werden pull-gesynct und in der Konfliktanzeige berücksichtigt.
model SelectedCalendar {
  id           String             @id @default(cuid())
  connection   CalendarConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  connectionId String
  externalId   String // Google calendar ID oder CalDAV URL
  displayName  String
  color        String? // Hex-Color aus dem Provider (Google liefert das)
  timezone     String?
  isPushTarget Boolean            @default(false)
  syncToken    String? // pro Kalender separat
  ctag         String? // CalDAV
  lastSyncedAt DateTime?
  createdAt    DateTime           @default(now())

  @@unique([connectionId, externalId])
  @@index([connectionId])
}

// Externe Termine aus den verbundenen Kalendern.
// Bewusst minimal: nur Zeitfenster für Konflikterkennung. Keine Inhalte, keine Teilnehmer.
// Bei Disconnect wird via onDelete Cascade alles gelöscht.
model ExternalCalendarEvent {
  id              String             @id @default(cuid())
  connection      CalendarConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  connectionId    String
  externalEventId String // Google event.id ODER CalDAV-Href ODER iCal-UID
  iCalUid         String? // stabil über Move/Copy
  startAt         DateTime
  endAt           DateTime
  summary         String? // optional, nur für UI-Hint (max 80 chars), KEINE Description/Location
  etag            String?
  isOurs          Boolean            @default(false) // von unserer App angelegt (extendedProperties / X-LISA-ORIGIN)
  ourShootingId     String? // Verknüpfung zu Shooting (für Roundtrip)
  // Alternative Verknüpfung zu einem konkreten Shooting-Termin — falls dieser
  // Event aus einer ShootingDate stammt (nicht aus dem Shooting selber).
  ourShootingDateId String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@unique([connectionId, externalEventId])
  @@index([connectionId, startAt, endAt])
  @@index([ourShootingId])
  @@index([ourShootingDateId])
}

// Idempotenz-Store für Stripe-Webhooks. Verhindert doppelte Verarbeitung bei Retries.
model StripeWebhookEvent {
  stripeEventId String   @id // Stripe event.id
  userId        String // welcher User-Account
  type          String // event.type
  invoiceId     String? // wenn auflösbar
  receivedAt    DateTime @default(now())
  processed     Boolean  @default(false)
  errorMessage  String?

  @@index([userId, receivedAt])
}

model InvoiceItem {
  id             String  @id @default(cuid())
  invoice        Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId      String
  title          String  @default("Leistung") // Hauptbezeichnung (einzeilig)
  description    String? // optional, ausführlich
  quantity       Float   @default(1)
  unit           String? @default("Pauschal")
  unitPriceCents Int
  totalCents     Int
  position       Int     @default(0)
}

// Angebote/Offerten — geht der Rechnung voraus. Lisa schickt einen Vorschlag,
// die Kundin kann via Public-Link annehmen oder ablehnen. Bei Annahme kann das
// Angebot in einen Rechnungs-Entwurf konvertiert werden (gleiche Items + Beträge).
model Offer {
  id                String      @id @default(cuid())
  number            String?     @unique // bei status >= SENT vergeben, eigener Counter
  status            String      @default("DRAFT") // DRAFT | SENT | ACCEPTED | DECLINED | EXPIRED | WITHDRAWN
  customer          Customer    @relation(fields: [customerId], references: [id])
  customerId        String
  shooting          Shooting?   @relation(fields: [shootingId], references: [id])
  shootingId        String?
  // Empfänger-Snapshot zum Zeitpunkt des Versands (immutable nach Issue).
  recipientName     String      @default("")
  recipientAddress  String      @default("")
  // Aussteller-Snapshot (analog Invoice — JSON).
  issuerSnapshot    String
  title             String      @default("Angebot")
  intro             String?     // freier Vorspann unter dem Titel
  notes             String?     // freier Hinweis (Bedingungen, Hinweise)
  internalNote      String?     // nicht auf dem PDF — nur für Lisa
  issueDate         DateTime    @default(now())
  validUntil        DateTime?   // Gültigkeitsfrist (z.B. 14 Tage)
  // Summen (immer mitgespeichert für schnelle Liste-Anzeige)
  subtotalCents     Int         @default(0)
  vatRate           Float       @default(19)
  isSmallBusiness   Boolean     @default(false)
  vatAmountCents    Int         @default(0)
  totalCents        Int         @default(0)
  items             OfferItem[]
  // Workflow-Stati
  sentAt            DateTime?
  acceptedAt        DateTime?
  declinedAt        DateTime?
  declineReason     String?
  // Wenn akzeptiert + konvertiert: Rückreferenz auf die generierte Rechnung
  convertedInvoice  Invoice?    @relation("OfferConvertedInvoice", fields: [convertedInvoiceId], references: [id])
  convertedInvoiceId String?    @unique
  // Public-Token für /k/o/[token] (Annahme/Ablehnung durch die Kundin)
  publicToken       String?     @unique
  // Tenant
  owner             User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId           String
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([ownerId])
  @@index([customerId])
  @@index([status])
}

model OfferItem {
  id             String  @id @default(cuid())
  offer          Offer   @relation(fields: [offerId], references: [id], onDelete: Cascade)
  offerId        String
  title          String  @default("Leistung")
  description    String?
  quantity       Float   @default(1)
  unit           String? @default("Pauschal")
  unitPriceCents Int
  totalCents     Int
  position       Int     @default(0)
}

model InvoiceReminder {
  id         String    @id @default(cuid())
  invoice    Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId  String
  level      Int // 1=Erinnerung, 2=1.Mahnung, 3=2.Mahnung
  feeCents   Int       @default(0)
  newDueDate DateTime
  sentAt     DateTime?
  issuedAt   DateTime  @default(now())
  pdfUrl     String?

  @@index([invoiceId, level])
}

model PaymentSchedule {
  id           String               @id @default(cuid())
  shooting     Shooting             @relation(fields: [shootingId], references: [id], onDelete: Cascade)
  shootingId   String               @unique
  installments PaymentInstallment[]
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  // Tenant
  owner        User                 @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId      String              

  @@index([ownerId])
}

model PaymentInstallment {
  id          String          @id @default(cuid())
  schedule    PaymentSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  scheduleId  String
  label       String // "Anzahlung bei Buchung", "Restbetrag am Shootingtag" …
  kind        String          @default("INTERIM") // DEPOSIT | INTERIM | FINAL
  amountCents Int
  dueDate     DateTime?
  position    Int             @default(0)
  invoice     Invoice?        @relation("InstallmentInvoice", fields: [invoiceId], references: [id])
  invoiceId   String?         @unique
  paidAt      DateTime?
}

model Customer {
  id             String              @id @default(cuid())
  // Stammdaten
  firstName      String
  lastName       String
  email          String?
  phone          String?
  birthday       DateTime?
  avatarUrl      String?
  // Rechnungsadresse
  billingStreet  String?
  billingZip     String?
  billingCity    String?
  billingCountry String?             @default("Deutschland")
  // Lieferadresse für Welcome-Package (kann von der Rechnungsadresse abweichen,
  // z.B. an Tante/Nachbarin, weil Lisa die Kundin überraschen will).
  // null = Rechnungsadresse verwenden.
  welcomeStreet  String?
  welcomeZip     String?
  welcomeCity    String?
  welcomeCountry String?
  welcomeNote    String? // „an Frau Müller, Nachbarin" / „bitte klingeln"
  // Lieferadresse für Fotoprodukte (Alben, Leinwände, Drucke).
  // null = Rechnungsadresse verwenden.
  deliveryStreet  String?
  deliveryZip     String?
  deliveryCity    String?
  deliveryCountry String?
  deliveryNote    String? // „Packstation 174, Kundennummer …"
  // DSGVO-Opt-in für Email-Benachrichtigungen. Default true (für Boudoir-Kontext OK,
  // Kundin hat aktiv gebucht). Lisa kann pro Kundin opt-out setzen.
  emailOptIn      Boolean             @default(true)
  // Reverse-Relation: dieser Customer wurde aus einem Lead konvertiert (optional).
  convertedFromLeads Lead[] @relation("LeadConvertedCustomer")
  // Social
  instagram      String?
  facebook       String?
  tiktok         String?
  website        String?
  // CRM
  status         CustomerStatus?     @relation(fields: [statusId], references: [id])
  statusId       String?
  source         String? // "Wie hat sie/er von mir erfahren?"
  internalNotes  String? // private Notizen, Markdown
  tags           Tag[]               @relation("CustomerTags")
  // Beziehungen
  shootings      Shooting[]
  activities     Activity[]
  tasks          Task[]
  invoices       Invoice[]
  offers         Offer[]
  companions     CustomerCompanion[]
  bookings       Booking[]
  // Tenant
  owner          User                @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId        String             
  // Meta
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([ownerId])
}

// Begleitperson / Mit-Ansprechpartner — z.B. Partner:in bei Couple-Shooting, Familienmitglieder.
// Bewusst am Kunden (nicht am Shooting) verankert, weil Beziehungen meist langfristig sind.
model CustomerCompanion {
  id           String    @id @default(cuid())
  customer     Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId   String
  firstName    String
  lastName     String?
  relationship String? // "Partner", "Kind", "Mutter", "Freundin", …
  birthday     DateTime?
  email        String?
  phone        String?
  notes        String?
  position     Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([customerId])
}

// -------------------- PAKETE --------------------

model Package {
  id                     String                     @id @default(cuid())
  name                   String
  description            String?
  coverUrl               String?
  // Paket-Art im modularen Modus: "all_in_one" (default), "deposit" (Anzahlungspaket),
  // "image_pack" (Bildpaket). Im all_in_one-Modus immer "all_in_one".
  kind                   String                     @default("all_in_one")
  price                  Float // in EUR
  // Standard-Zahlungsbedingungen (Vorgabe, pro Shooting überschreibbar)
  depositAmount          Float? // z.B. 100€ Anzahlung
  paymentTerms           String? // Freitext, z.B. "50% bei Buchung, Rest am Shootingtag"
  durationMin            Int? // Standard-Dauer in Minuten — wird im Kalender als Block reserviert
  // Vor-/Nach-Bereitungs-Puffer: Lisa braucht Zeit für Aufbau (z.B. Boudoir-Setup) und
  // Nachbereitung. Beim Slot-Finden wird dieser Puffer um die Termin-Dauer gespannt.
  bookingBufferBeforeMin Int                        @default(0)
  bookingBufferAfterMin  Int                        @default(15)
  isActive               Boolean                    @default(true)
  position               Int                        @default(0)
  shootings              Shooting[]                 @relation("ShootingPrimaryPackage")
  imageShootings         Shooting[]                 @relation("ShootingImagePackage")
  checklistTemplates     PackageChecklistTemplate[]
  documents              PackageDocument[]
  defaultQuestionnaires  QuestionnaireTemplate[]    @relation("PackageDefaultQuestionnaires")
  // Default-Team für neue Shootings
  primaryContact         TeamMember?                @relation("PackageDefaultContact", fields: [primaryContactId], references: [id])
  primaryContactId       String?
  defaultTeam            TeamMember[]               @relation("PackageDefaultTeam")
  // Verfügbare Zusatzprodukte für dieses Paket (Bilderbuch M, Leinwand …)
  addons                 Addon[]                    @relation("PackageAddons")
  createdAt              DateTime                   @default(now())
  updatedAt              DateTime                   @updatedAt
  // Tenant
  owner                  User                       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId                String                    

  @@index([ownerId])
}

// Dokumente, die zu einem Paket gehören (Prep Guide, Outfit Guide, …).
// Werden im Kunden-Dashboard (/k/[slug]) zum Download angezeigt — Tenant-Isolation
// passiert via Package.ownerId; das Dokument selbst trägt keine eigene ownerId.
model PackageDocument {
  id          String   @id @default(cuid())
  package     Package  @relation(fields: [packageId], references: [id], onDelete: Cascade)
  packageId   String
  title       String   // z.B. "Prep Guide", "Outfit-Inspiration"
  description String?  // 1-2 Zeilen Kontext für die Kundin
  fileUrl     String   // Public-URL (Supabase Storage)
  filename    String   // Original-Dateiname (für Download-Header)
  mimeType    String   // application/pdf, image/png, …
  sizeBytes   Int
  position    Int      @default(0)
  isVisible   Boolean  @default(true) // off = im Studio sichtbar, aber nicht für Kundin
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([packageId])
}

// Zusatzprodukte (Bilderbuch M, Leinwand 60x90, Make-up-Service …)
// Kann zu mehreren Paketen verknüpft sein (als „verfügbar"). Konkrete Buchung pro Shooting
// läuft über ShootingAddon (Join mit Quantity + unitPrice-Snapshot).
model Addon {
  id               String          @id @default(cuid())
  name             String
  description      String?
  imageUrl         String?
  imageOriginalUrl String?
  imageMimeType    String?
  price            Float // EUR — wird beim Buchen als unitPrice in ShootingAddon kopiert
  isActive         Boolean         @default(true)
  position         Int             @default(0)
  packages         Package[]       @relation("PackageAddons")
  bookings         ShootingAddon[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  // Tenant
  owner            User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId          String         

  @@index([ownerId])
}

// Buchung eines Add-Ons in einem Shooting.
// unitPrice ist ein SNAPSHOT zum Buchungszeitpunkt — schützt vor rückwirkenden Preis-Drifts,
// wenn Lisa den Add-On-Preis später ändert.
model ShootingAddon {
  id         String   @id @default(cuid())
  shooting   Shooting @relation(fields: [shootingId], references: [id], onDelete: Cascade)
  shootingId String
  addon      Addon    @relation(fields: [addonId], references: [id], onDelete: Restrict)
  addonId    String
  quantity   Int      @default(1)
  unitPrice  Float // Snapshot bei Buchung
  position   Int      @default(0)
  createdAt  DateTime @default(now())

  @@unique([shootingId, addonId])
  @@index([shootingId])
  @@index([addonId])
}

model PackageChecklistTemplate {
  id        String                 @id @default(cuid())
  package   Package                @relation(fields: [packageId], references: [id], onDelete: Cascade)
  packageId String
  title     String
  audience  String                 @default("INTERNAL") // INTERNAL | CUSTOMER
  position  Int                    @default(0)
  items     PackageChecklistItem[]

  @@index([packageId])
}

model PackageChecklistItem {
  id         String                   @id @default(cuid())
  template   PackageChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  templateId String
  label      String
  position   Int                      @default(0)
}

// -------------------- SHOOTINGS --------------------

model ShootingStatus {
  id        String     @id @default(cuid())
  label     String
  color     String
  position  Int        @default(0)
  isDefault Boolean    @default(false)
  // Workflow-Flags
  isDone    Boolean    @default(false) // markiert "Abgeschlossen"-artige Status
  shootings Shooting[]
  // Tenant
  owner     User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId   String    

  @@unique([ownerId, label])
  @@index([ownerId])
}

model Shooting {
  id               String           @id @default(cuid())
  title            String // z.B. "Boudoir-Shooting Anna"
  publicSlug       String? // für Kundenansicht /k/[slug]
  customer         Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId       String
  // Primärpaket: bei „all_in_one" das Komplettpaket, bei „modular" das Anzahlungspaket.
  package          Package?         @relation("ShootingPrimaryPackage", fields: [packageId], references: [id])
  packageId        String?
  // Modular-Modus: optionales Bildpaket (wird bei der Bildauswahl gewählt).
  imagePackage     Package?         @relation("ShootingImagePackage", fields: [imagePackageId], references: [id])
  imagePackageId   String?
  status           ShootingStatus?  @relation(fields: [statusId], references: [id])
  statusId         String?
  description      String?
  scheduledAt      DateTime?
  durationMin      Int?
  location         String?
  price            Float
  depositAmount    Float?
  depositPaid      Boolean          @default(false)
  finalPaid        Boolean          @default(false)
  paymentTerms     String?
  // Team
  primaryContact   TeamMember?      @relation("ShootingPrimaryContact", fields: [primaryContactId], references: [id])
  primaryContactId String?
  team             TeamMember[]     @relation("ShootingTeam")
  // Public-Visibility: zeigt der „Team"-Block in der Kundenansicht? Default an.
  showTeamOnPublic Boolean          @default(true)
  // Gebuchte Zusatzprodukte (Bilderbuch M, Leinwand etc.) — Quantity + Preis-Snapshot in ShootingAddon
  addons           ShootingAddon[]
  // Inhalt
  dates            ShootingDate[]
  notes            ShootingNote[]
  checklists       Checklist[]
  attachments      Attachment[]
  tasks            Task[]
  activities       Activity[]
  questionnaires   Questionnaire[]
  invoices         Invoice[]
  offers           Offer[]
  paymentSchedule  PaymentSchedule?
  bookings         Booking[]
  kanbanPosition   Int              @default(0)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  // Tenant
  owner            User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId          String          

  @@unique([ownerId, publicSlug])
  @@index([customerId])
  @@index([statusId])
  @@index([scheduledAt])
  @@index([ownerId])
}

model ShootingDate {
  id          String       @id @default(cuid())
  shooting    Shooting     @relation(fields: [shootingId], references: [id], onDelete: Cascade)
  shootingId  String
  label       String // z.B. "Fitting", "Shooting", "Bildauswahl"
  startAt     DateTime
  endAt       DateTime?
  location    String?
  locationUrl String? // Maps-Link
  description String? // optional, kurze Info für die Kundin
  position    Int          @default(0)
  // Opt-in pro Termin: wenn true, wird der Termin in alle aktiven Kalender-
  // Verbindungen gepusht (analog zu Shootings, aber separat steuerbar).
  syncToCalendar Boolean   @default(false)
  // Dateien, die diesem konkreten Termin zugeordnet sind (z.B. Fitting-Checkliste).
  attachments    Attachment[]

  @@index([shootingId, startAt])
}

model ShootingNote {
  id         String   @id @default(cuid())
  shooting   Shooting @relation(fields: [shootingId], references: [id], onDelete: Cascade)
  shootingId String
  text       String
  status     String   @default("OPEN") // OPEN | DONE | IMPORTANT
  // Kategorie für Phasen-Splitting im Workflow (Erstgespräch/Bildauswahl/Retusche/Allgemein).
  // Frei-erweiterbar; Default "ALLGEMEIN" für Backwards-Kompat.
  category   String   @default("ALLGEMEIN")
  createdAt  DateTime @default(now())

  @@index([shootingId])
  @@index([shootingId, category])
}

// Artikel-Katalog: vorgefertigte Rechnungs-Positionen, die Lisa bei der
// Rechnungs-Erstellung schnell auswählen kann. Trennung nach kind:
//   "SERVICE" = Dienstleistung (z.B. „Boudoir-Shooting 2h", „Make-up")
//   "PRODUCT" = Produkt (z.B. „Bilderbuch M", „Leinwand 60x90")
// Item-Daten werden in InvoiceItem kopiert (Snapshot), Katalog-Änderungen
// betreffen alte Rechnungen NICHT.
model ArticleCatalog {
  id           String   @id @default(cuid())
  name         String
  description  String?
  kind         String   @default("SERVICE") // "SERVICE" | "PRODUCT"
  unit         String?  @default("Pauschal")
  defaultPriceCents Int @default(0)
  position     Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  // Tenant
  owner        User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId      String

  @@index([ownerId])
  @@index([ownerId, kind])
}

// User-konfigurierbare Notiz-Vorlagen mit Leitfragen (z.B. „Wie hast du mich
// gefunden? Was für Bilder wünschst du dir? …" für Erstgespräche).
// Lisa kann pro Kategorie mehrere Templates anlegen und sie beim Anlegen einer
// Notiz auswählen — der Body wird als Initial-Text in die Textarea geladen.
model NoteTemplate {
  id        String   @id @default(cuid())
  name      String
  category  String   @default("ALLGEMEIN")
  body      String   // mehrzeilig, Plain-Text
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  // Tenant
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId   String

  @@index([ownerId])
  @@index([ownerId, category])
}

model Checklist {
  id         String          @id @default(cuid())
  title      String // z.B. "Was bringt die Kundin mit?"
  audience   String          @default("INTERNAL") // INTERNAL | CUSTOMER
  position   Int             @default(0)
  shooting   Shooting        @relation(fields: [shootingId], references: [id], onDelete: Cascade)
  shootingId String
  items      ChecklistItem[]

  @@index([shootingId, audience])
}

model ChecklistItem {
  id          String    @id @default(cuid())
  label       String
  done        Boolean   @default(false)
  dueAt       DateTime?
  position    Int       @default(0)
  checklist   Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  checklistId String

  @@index([done, dueAt])
}

model Attachment {
  id              String        @id @default(cuid())
  filename        String
  url             String
  mimeType        String?
  sizeBytes       Int?
  // Wer hat hochgeladen: "STUDIO" (Lisa) oder "CUSTOMER" (Kundin via Public-Page).
  // Default "STUDIO" für Backwards-Compat; Public-Upload-Endpoints setzen "CUSTOMER".
  uploadedBy      String        @default("STUDIO")
  shooting        Shooting      @relation(fields: [shootingId], references: [id], onDelete: Cascade)
  shootingId      String
  // Optional: zu welchem konkreten Termin gehört diese Datei (z.B. Fitting-Checkliste).
  // SetNull bei Date-Delete → Datei bleibt im Shooting erhalten, nur Zuordnung weg.
  shootingDate    ShootingDate? @relation(fields: [shootingDateId], references: [id], onDelete: SetNull)
  shootingDateId  String?
  createdAt       DateTime      @default(now())

  @@index([shootingDateId])
}

// -------------------- FRAGEBÖGEN --------------------

model Questionnaire {
  id             String                @id @default(cuid())
  shooting       Shooting              @relation(fields: [shootingId], references: [id], onDelete: Cascade)
  shootingId     String
  title          String
  description    String?
  // Lifecycle
  status         String                @default("DRAFT") // DRAFT | SENT | OPENED | IN_PROGRESS | SUBMITTED
  sentAt         DateTime?
  openedAt       DateTime?
  lastSavedAt    DateTime?
  submittedAt    DateTime?
  seenByStudioAt DateTime? // wann Studio den abgeschickten Bogen zuletzt angesehen hat
  fields         QuestionnaireField[]
  answers        QuestionnaireAnswer[]
  position       Int                   @default(0)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([shootingId])
  @@index([status, submittedAt])
}

model QuestionnaireField {
  id              String                @id @default(cuid())
  questionnaire   Questionnaire         @relation(fields: [questionnaireId], references: [id], onDelete: Cascade)
  questionnaireId String
  type            String // TEXT TEXTAREA NUMBER EMAIL PHONE DATE SELECT_SINGLE SELECT_MULTI YES_NO RATING FILE
  label           String
  helpText        String?
  required        Boolean               @default(false)
  options         String? // JSON-Array für SELECT_*
  position        Int                   @default(0)
  answers         QuestionnaireAnswer[]

  @@index([questionnaireId])
}

model QuestionnaireTemplate {
  id          String                       @id @default(cuid())
  title       String
  description String?
  fields      QuestionnaireTemplateField[]
  packages    Package[]                    @relation("PackageDefaultQuestionnaires")
  position    Int                          @default(0)
  createdAt   DateTime                     @default(now())
  updatedAt   DateTime                     @updatedAt
  // Tenant
  owner       User                         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId     String                      

  @@index([ownerId])
}

model QuestionnaireTemplateField {
  id         String                @id @default(cuid())
  template   QuestionnaireTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  templateId String
  type       String
  label      String
  helpText   String?
  required   Boolean               @default(false)
  options    String?
  position   Int                   @default(0)

  @@index([templateId])
}

model QuestionnaireAnswer {
  id              String             @id @default(cuid())
  questionnaire   Questionnaire      @relation(fields: [questionnaireId], references: [id], onDelete: Cascade)
  questionnaireId String
  field           QuestionnaireField @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  fieldId         String
  textValue       String?
  numberValue     Float?
  dateValue       DateTime?
  boolValue       Boolean?
  jsonValue       String? // SELECT_MULTI, SELECT_SINGLE (Label), FILE ({url,filename,size,mime})
  updatedAt       DateTime           @updatedAt

  @@unique([questionnaireId, fieldId])
}

// -------------------- AUFGABEN --------------------

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  done        Boolean   @default(false)
  dueAt       DateTime?
  // Optional verknüpft
  customer    Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId  String?
  shooting    Shooting? @relation(fields: [shootingId], references: [id], onDelete: Cascade)
  shootingId  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  // Tenant
  owner       User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId     String   

  @@index([done, dueAt])
  @@index([customerId])
  @@index([shootingId])
  @@index([ownerId])
}

// -------------------- AKTIVITÄT (LOG) --------------------

model Activity {
  id         String    @id @default(cuid())
  kind       String // "customer_created" | "customer_status_changed" | "note_added" | "shooting_created" | "shooting_status_changed" | "payment_received" | ...
  message    String // menschenlesbar
  meta       String? // optional JSON
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId String?
  shooting   Shooting? @relation(fields: [shootingId], references: [id], onDelete: Cascade)
  shootingId String?
  createdAt  DateTime  @default(now())
  // Tenant
  owner      User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId    String   

  @@index([customerId, createdAt])
  @@index([shootingId, createdAt])
  @@index([ownerId])
}

// -------------------- VERFÜGBARKEIT --------------------
// Verfügbarkeit pro Wochentag (0=Sonntag..6=Samstag).
// isAvailable=false → Tag generell zu (kein Termin buchbar, egal welche Zeit).
// slotsJson: JSON-Array von { start, end } in Minuten seit Mitternacht (lokal),
//   z.B. [{ "start": 540, "end": 870 }, { "start": 960, "end": 1155 }]
//   = Mo 09:00-14:30 + 16:00-19:15.
//   Null/leer + isAvailable=true → User-Default-Tagesfenster wird verwendet
//   (User.defaultDayStartMinutes/EndMinutes — z.B. „ganzer Tag 9-18 Uhr").
model AvailabilityWeekly {
  id          String   @id @default(cuid())
  weekday     Int // 0..6
  isAvailable Boolean  @default(false)
  slotsJson   String?
  updatedAt   DateTime @updatedAt
  // Tenant
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId     String  

  @@unique([ownerId, weekday])
  @@index([ownerId])
}

// Tag-Override: konkretes Datum überschreibt die Wochenregel.
// `date` als String "YYYY-MM-DD" vermeidet Timezone-Edge-Cases beim Vergleich.
// Semantik wie AvailabilityWeekly: isAvailable + slotsJson.
model AvailabilityOverride {
  id          String   @id @default(cuid())
  date        String // "YYYY-MM-DD"
  isAvailable Boolean  @default(false)
  slotsJson   String?
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  // Tenant
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId     String

  @@unique([ownerId, date])
  @@index([ownerId])
}

// Lead = Interessentin, die sich über ein öffentliches Formular gemeldet hat.
// Workflow: NEW → CONTACTED → CONSULTATION_BOOKED → CONSULTATION_DONE → CONVERTED (oder LOST).
// Beim CONVERTED wird ein Customer angelegt und via `convertedCustomerId` verknüpft.
model Lead {
  id                String   @id @default(cuid())
  firstName         String
  lastName          String?
  email             String
  phone             String?
  message           String?
  packageInterest   String?  // Freitext, kein FK — Lisa pflegt Pakete später
  preferredDate     String?  // YYYY-MM-DD als String, weil Wunsch-„circa-Datum"
  source            String?  // „Instagram", „Empfehlung von Anna" etc.
  status            String   @default("NEW") // NEW | CONTACTED | CONSULTATION_BOOKED | CONSULTATION_DONE | CONVERTED | LOST
  consultationAt    DateTime?
  consultationNotes String?
  internalNotes     String?
  // Spam-Mitigation: IP-Hash zur lokalen Rate-Limit-Heuristik
  ipHash            String?
  // Convert-FK
  convertedCustomer Customer? @relation("LeadConvertedCustomer", fields: [convertedCustomerId], references: [id], onDelete: SetNull)
  convertedCustomerId String?
  // Tenant
  owner   User    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId, status])
  @@index([ownerId, createdAt])
}

// Shooting-Slot-Planung: Lisa markiert Tage vorab als „Slot-Tag" — damit sie
// die Buchungen pro Zeitraum bewusst limitieren kann. Diese Tage werden im
// Kalender mit farbigem Rahmen + 20%-Fill hervorgehoben.
model ShootingPlanDay {
  id        String   @id @default(cuid())
  date      String // "YYYY-MM-DD"
  color     String   @default("#C8102E") // Hex
  label     String? // optional: „Boudoir-Tag", „Family-Sessions" …
  createdAt DateTime @default(now())
  // Tenant
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId   String

  @@unique([ownerId, date])
  @@index([ownerId])
}

// -------------------- ONLINE-BUCHUNG (Calendly-Double) --------------------

// Buchungs-Typ: ein öffentlich teilbarer Termin-Slot-Typ.
// Beispiel: "Erstgespräch — 30 Min kostenlos", "Boudoir-Beratung — 60 Min, 50€".
// Public-URL: /b/[slug]. Verfügbare Slots werden aus AvailabilityWeekly + bestehenden
// Shootings/Bookings dynamisch generiert (siehe lib/bookingSlots.ts).
model BookingType {
  id                 String    @id @default(cuid())
  slug               String
  name               String
  description        String?
  durationMin        Int       @default(30)
  // Preis in Cent (0 = kostenlos). Wird nur informativ auf der Buchungsseite gezeigt,
  // keine Zahlung im Online-Flow — Zahlung läuft bei Lisa weiter über Rechnung/Stripe.
  priceCents         Int       @default(0)
  // Puffer in Minuten vor/nach dem Termin — verhindert dass Lisa zwei Termine direkt
  // hintereinander hat (Wechselzeit, Vorbereitung).
  bufferBeforeMin    Int       @default(0)
  bufferAfterMin     Int       @default(15)
  // Mindest-Vorlaufzeit: keine Buchung weniger als X Stunden im Voraus möglich.
  minLeadHours       Int       @default(24)
  // Maximaler Buchungs-Horizont: nicht weiter als N Tage in der Zukunft buchbar.
  maxAheadDays       Int       @default(60)
  // Slot-Raster: in welchen Intervallen werden Slots angeboten (15, 30, 60 Min).
  slotIntervalMin    Int       @default(30)
  location           String? // Legacy-Fallback; neue UI nutzt locationsJson
  // JSON-Array von Termin-Orten: [{ "key": "studio"|"phone"|"video"|"home"|"custom", "label": "..." }]
  // Multiple möglich — Kundin sieht alle als Info auf der Buchungsseite.
  locationsJson      String?
  // Wenn „video" als Ort aktiv ist: welcher Provider liefert den Meeting-Link?
  // Werte: "zoom" | "google_meet" | "teams" | "whereby" | "manual" | null
  videoProvider      String?
  // JSON-Array von zusätzlichen Pflicht-/Optional-Feldern für die Buchungs-Form.
  // Format: [{ "id", "type", "label", "placeholder"?, "required" }]
  // type: "text"|"textarea"|"phone"|"email"|"select"|"checkbox"
  // Wenn null: Fallback auf alte requirePhone/requireMessage Toggles.
  requiredFieldsJson String?
  // Auto-Confirm: PENDING springt sofort auf CONFIRMED beim Buchen.
  // Sonst muss Lisa in der Inbox manuell annehmen.
  autoConfirm        Boolean   @default(false)
  // Welche Pflichtfelder im Formular: Name + Email immer; Phone und Message optional.
  requirePhone       Boolean   @default(true)
  requireMessage     Boolean   @default(false)
  color              String    @default("#9F877F")
  isActive           Boolean   @default(true)
  position           Int       @default(0)
  bookings           Booking[]
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  // Tenant
  owner              User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId            String   

  @@unique([ownerId, slug])
  @@index([ownerId])
}

// BookingStatus als String — SQLite hat keine Enum-Unterstützung. Erlaubt: "PENDING" | "CONFIRMED" | "CANCELLED".

// Eine konkrete Online-Buchung durch eine Kundin.
// Snapshot der Eingaben (customerName/Email/Phone/message) bleibt unabhängig vom
// später ggf. verknüpften Customer-Record erhalten.
model Booking {
  id              String      @id @default(cuid())
  bookingType     BookingType @relation(fields: [bookingTypeId], references: [id], onDelete: Cascade)
  bookingTypeId   String
  // Kundinnen-Daten als Snapshot zum Buchungszeitpunkt
  customerName    String
  customerEmail   String
  customerPhone   String?
  message         String?
  // Termin
  startAt         DateTime
  endAt           DateTime
  status          String      @default("PENDING") // PENDING | CONFIRMED | CANCELLED
  // Nach „Annehmen" im CRM: optional verknüpfte Customer/Shooting-Records
  customer        Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerId      String?
  shooting        Shooting?   @relation(fields: [shootingId], references: [id], onDelete: SetNull)
  shootingId      String?
  // Online-Meeting-Link, falls BookingType.videoProvider gesetzt war beim Anlegen.
  // Snapshot — bleibt stabil auch wenn Lisa später ihren persönlichen Link ändert.
  meetingUrl      String?
  meetingProvider String?
  // Audit
  confirmedAt     DateTime?
  cancelledAt     DateTime?
  cancelReason    String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  // Tenant
  owner           User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId         String     

  @@index([bookingTypeId, startAt])
  @@index([status, startAt])
  @@index([ownerId])
}

// ---------- Workflow-Automation ----------
//
// Ein Workflow ist eine Sequenz von Actions, die durch ein Trigger-Event
// ausgelöst werden (z.B. „Rechnung bezahlt", „Angebot angenommen"). Jeder
// Step hat eine Verzögerung in Minuten — 0 = sofort, sonst wird ein Job
// erzeugt, den der Cron-Worker /api/cron/workflows später abarbeitet.

model Workflow {
  id          String         @id @default(cuid())
  name        String
  description String?
  // Trigger-Event-Typ: "invoice_paid" | "offer_accepted" | "lead_created"
  // | "manual" (nur manuell ausführbar, z.B. „Welcome-Sequenz starten")
  trigger     String
  isActive    Boolean        @default(true)
  steps       WorkflowStep[]
  runs        WorkflowRun[]
  owner       User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId     String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([ownerId])
  @@index([ownerId, trigger, isActive])
}

model WorkflowStep {
  id           String   @id @default(cuid())
  workflow     Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  workflowId   String
  position     Int      @default(0)
  // Verzögerung ab Trigger-Zeitpunkt. 0 = sofort, 1440 = 1 Tag.
  delayMinutes Int      @default(0)
  // "email" | "task"
  actionType   String
  // JSON-Config je nach actionType:
  //  email: { to: "customer" | "owner", subject, body }
  //  task:  { title, description, dueInDays }
  config       String
}

model WorkflowRun {
  id          String        @id @default(cuid())
  workflow    Workflow      @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  workflowId  String
  triggeredAt DateTime      @default(now())
  // Kontext: welche Entitäten gehören zu diesem Lauf? Werden für die Template-
  // Variablen-Auflösung und für die Cleanup-Anzeige genutzt.
  customerId  String?
  invoiceId   String?
  offerId     String?
  shootingId  String?
  leadId      String?
  status      String        @default("pending") // pending | done | failed | cancelled
  jobs        WorkflowJob[]
  owner       User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId     String

  @@index([ownerId])
  @@index([workflowId])
}

model WorkflowJob {
  id         String      @id @default(cuid())
  run        WorkflowRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  runId      String
  // Snapshot des Steps zum Zeitpunkt des Triggers. Falls Lisa den Workflow
  // später ändert, läuft der Job mit der eingefrorenen Config.
  stepPosition Int
  actionType String
  configSnapshot String // JSON
  runAt      DateTime
  status     String      @default("pending") // pending | done | failed | cancelled
  result     String?     // JSON mit log/error
  executedAt DateTime?

  @@index([status, runAt])
}
